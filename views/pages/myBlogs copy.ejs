<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Manage your blog posts on BlogSphere.">
    <title>My Blogs — BlogSphere</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/dist/css/pages.css" rel="stylesheet">
</head>

<body>

    <div class="dashboard-wrapper">
        <aside class="dashboard-sidebar">
            <div class="sidebar-brand"><i class="bi bi-globe2 me-2"></i>BlogSphere</div>
            <div class="sidebar-section-title">Main Menu</div>
            <nav class="sidebar-nav">
                <a href="/dashboard" class="nav-link"><i class="bi bi-speedometer2"></i> Dashboard</a>
                <a href="/blog/create-Blog"class="nav-link"><i class="bi bi-plus-circle"></i> Create Blog</a>
                <a href="/blog/myBlog" class="nav-link active"><i class="bi bi-journal-text"></i> My Blogs</a>
                <a href="/blog/logout" class="nav-link"><i class="bi bi-person-gear"></i> Logout</a>
            </nav>
            <div class="sidebar-section-title">Quick Links</div>
            <nav class="sidebar-nav">
                <a href="../../index.html" class="nav-link"><i class="bi bi-house"></i> Back to Home</a>
            </nav>
        </aside>

        <div class="dashboard-content">
            <div class="dashboard-topbar">
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-ghost d-lg-none" onclick="toggleSidebar()"><i class="bi bi-list"
                            style="font-size:22px;"></i></button>
                    <div class="topbar-title">
                        <h4>My Blogs</h4>
                        <p>Manage your articles</p>
                    </div>
                </div>
                <div class="topbar-actions">
                    <a href="/blog/create-Blog" class="btn btn-gradient"><i class="bi bi-plus me-1"></i> New Blog</a>
                </div>
            </div>

            <div class="dashboard-main">
                <!-- Filters -->
                <div class="card-custom p-3 mb-4 fade-in">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                        <div class="d-flex gap-2">
                            <button class="btn btn-gradient btn-sm" data-filter="all">All</button>
                            <button class="btn btn-ghost btn-sm" data-filter="published">Published</button>
                            <button class="btn btn-ghost btn-sm" data-filter="draft">Drafts</button>
                            <button class="btn btn-ghost btn-sm" data-filter="pending">Pending</button>
                        </div>
                        <div class="search-bar" style="max-width:300px;">
                            <i class="bi bi-search"></i>
                            <input type="text" id="blogSearch" placeholder="Search my blogs..." class="form-control"
                                style="padding:10px 16px 10px 40px; font-size:14px;">
                        </div>
                    </div>
                </div>

          <div class="row g-4">
                    <!-- Recent Blogs -->
                    <div class="col-lg-8">
                        <div class="card-custom p-4 fade-in">
                            <div class="d-flex align-items-center justify-content-between mb-4">
                                <h5 class="mb-0"><i class="bi bi-clock-history me-2 text-primary-custom"></i>My
                                    Blogs</h5>
                                <a href="my-blogs.html" class="text-small text-primary-custom">View All <i
                                        class="bi bi-arrow-right"></i></a>
                            </div>
                            <div>

                                <% blogs.forEach(blog=> {

                                    const { title, description, excerpt , tags, createdAt, image } = blog;

                                    %>

                                    <div class="d-flex gap-3 mb-4 pb-4 mt-5">

                                        <a href="/blog/blogPage/<%= blog._id %>">
                                            <img src="/uploads/<%= blog.image %>" width="150px" class="blog-thumb">
                                        </a>
                                        <div>

                                            <h6 class="mb-1">
                                                <%= title %>
                                            </h6>

                                            <p class="mb-1 text-small text-muted-custom">
                                                <%= excerpt %>
                                            </p>
                                                <p class="mb-1 text-small text-muted-custom">
                                                <%= tags %>
                                            </p>

                                            <small class="text-muted">
                                                <%= createdAt %>
                                            </small>

                                        </div>


                                    </div>
                                    <div class="d-flex gap-3 border-bottom border-3 pb-4">
                                        <a href="/blog/delete/<%= blog._id %>" class="btn btn-danger gap-2"
                                            style="font-size: 12px;">Delete</a>
                                        <a href="/blog/editBlog/<%= blog._id %>" class="btn btn-warning " style="font-size: 12px;">Update</a>
                                    </div>

                                    <% }) %>

                            </div>
                        </div>
                    </div>

                    <!-- Activity & Quick Actions -->
                    <div class="col-lg-4">
                        <!-- Quick Actions -->
                        <div class="card-custom p-4 mb-4 fade-in">
                            <h5 class="mb-3"><i class="bi bi-lightning me-2 text-primary-custom"></i>Quick Actions</h5>
                            <div class="d-grid gap-2">
                                <a href="/blog/create-Blog" class="btn btn-gradient"><i
                                        class="bi bi-plus-circle me-2"></i> Write New Blog</a>
                                <a href="my-blogs.html" class="btn btn-outline-gradient"><i
                                        class="bi bi-journal-text me-2"></i> Manage Blogs</a>
                                <a href="/user/updateProfile" class="btn btn-ghost border"><i
                                        class="bi bi-gear me-2"></i> Edit Profile</a>
                            </div>
                        </div>

                        <!-- Recent Activity -->
                        <div class="card-custom p-4 fade-in">
                            <h5 class="mb-3"><i class="bi bi-activity me-2 text-primary-custom"></i>Recent Activity</h5>
                            <div id="activityList">
                                <div class="d-flex gap-3 mb-3 pb-3 border-bottom">
                                    <div class="btn-icon"
                                        style="flex-shrink:0; background:rgba(46,204,113,0.1); color:var(--clr-success);">
                                        <i class="bi bi-heart-fill"></i>
                                    </div>
                                    <div>
                                        <p class="mb-0 text-small"><strong>Ananya</strong> liked your blog</p>
                                        <small class="text-muted-custom">2 hours ago</small>
                                    </div>
                                </div>
                                <div class="d-flex gap-3 mb-3 pb-3 border-bottom">
                                    <div class="btn-icon"
                                        style="flex-shrink:0; background:rgba(102,126,234,0.1); color:var(--clr-primary);">
                                        <i class="bi bi-chat-fill"></i>
                                    </div>
                                    <div>
                                        <p class="mb-0 text-small"><strong>Rahul</strong> commented on "Building
                                            Scalable Apps"</p>
                                        <small class="text-muted-custom">5 hours ago</small>
                                    </div>
                                </div>
                                <div class="d-flex gap-3 mb-3 pb-3 border-bottom">
                                    <div class="btn-icon"
                                        style="flex-shrink:0; background:rgba(243,156,18,0.1); color:var(--clr-warning);">
                                        <i class="bi bi-person-plus-fill"></i>
                                    </div>
                                    <div>
                                        <p class="mb-0 text-small"><strong>Priya</strong> started following you</p>
                                        <small class="text-muted-custom">1 day ago</small>
                                    </div>
                                </div>
                                <div class="d-flex gap-3">
                                    <div class="btn-icon"
                                        style="flex-shrink:0; background:rgba(118,75,162,0.1); color:var(--clr-secondary);">
                                        <i class="bi bi-trophy-fill"></i>
                                    </div>
                                    <div>
                                        <p class="mb-0 text-small">Your blog reached <strong>1K views!</strong></p>
                                        <small class="text-muted-custom">2 days ago</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:var(--radius-modal); border:none;">
                <div class="modal-body text-center p-5">
                    <div
                        style="width:72px; height:72px; border-radius:50%; background:rgba(231,76,60,0.1); display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
                        <i class="bi bi-trash" style="font-size:32px; color:var(--clr-error);"></i>
                    </div>
                    <h4>Delete Blog?</h4>
                    <p class="text-muted-custom">This action cannot be undone. The blog post will be permanently
                        removed.</p>
                    <div class="d-flex gap-2 justify-content-center mt-4">
                        <button class="btn btn-ghost border px-4" data-bs-dismiss="modal">Cancel</button>
                        <button class="btn px-4"
                            style="background:var(--clr-error); color:#fff; border-radius:var(--radius-btn);"
                            id="confirmDelete">Delete</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="toastContainer" style="position:fixed; top:80px; right:20px; z-index:9999; width:360px;"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="../../models/blogModel.js"></script>
    <script src="../../models/BlogModel.js"></script>
    <script src="../../models/CategoryModel.js"></script>
    <script src="../../models/CommentModel.js"></script>
    <script src="../../controllers/MainController.js"></script>
   
</body>

</html>