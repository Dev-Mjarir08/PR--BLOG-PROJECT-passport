<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Create a new blog post on BlogSphere.">
    <title>Create Blog — BlogSphere</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="../../assets/css/styles.css" rel="stylesheet">
    <style>
        .image-upload-area {
            border: 2px dashed var(--clr-border);
            border-radius: var(--radius-card);
            padding: 48px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition);
            background: var(--clr-surface);
        }

        .image-upload-area:hover {
            border-color: var(--clr-primary);
            background: rgba(102, 126, 234, 0.04);
        }

        .image-upload-area.dragging {
            border-color: var(--clr-primary);
            background: rgba(102, 126, 234, 0.08);
        }

        .tag-input-wrapper {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            padding: 8px;
            border: 2px solid var(--clr-border);
            border-radius: var(--radius-input);
            background: var(--clr-card);
            min-height: 48px;
            align-items: center;
        }

        .tag-input-wrapper:focus-within {
            border-color: var(--clr-primary);
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.12);
        }

        .tag-input-wrapper input {
            border: none;
            outline: none;
            flex: 1;
            min-width: 120px;
            font-family: var(--font-body);
            font-size: 15px;
        }

        .tag-badge {
            background: var(--clr-gradient);
            color: #fff;
            padding: 4px 12px;
            border-radius: var(--radius-pill);
            font-size: 13px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .tag-badge .remove-tag {
            cursor: pointer;
            opacity: 0.7;
        }

        .tag-badge .remove-tag:hover {
            opacity: 1;
        }

        .editor-toolbar {
            background: var(--clr-surface);
            border: 2px solid var(--clr-border);
            border-bottom: none;
            border-radius: var(--radius-input) var(--radius-input) 0 0;
            padding: 8px 12px;
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
        }

        .editor-toolbar button {
            background: transparent;
            border: none;
            padding: 6px 10px;
            border-radius: 4px;
            color: var(--clr-text-secondary);
            cursor: pointer;
            transition: var(--transition);
        }

        .editor-toolbar button:hover {
            background: var(--clr-gradient-light);
            color: var(--clr-primary);
        }

        .editor-area {
            border: 2px solid var(--clr-border);
            border-top: none;
            border-radius: 0 0 var(--radius-input) var(--radius-input);
            min-height: 300px;
            padding: 16px;
            font-family: var(--font-body);
            font-size: 16px;
            line-height: 1.7;
        }

        .editor-area:focus {
            outline: none;
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.12);
            border-color: var(--clr-primary);
        }
    </style>
</head>

<body>

    <div class="dashboard-wrapper">
        <!-- SIDEBAR -->
        <aside class="dashboard-sidebar" id="dashboardSidebar">
            <div class="sidebar-brand"><i class="bi bi-globe2 me-2"></i>BlogSphere</div>
            <div class="sidebar-section-title">Main Menu</div>
            <nav class="sidebar-nav">
                <a href="/user/userDashboard" class="nav-link"><i class="bi bi-speedometer2"></i> Dashboard</a>
                <a href="/blog/create-Blog" class="nav-link active"><i class="bi bi-plus-circle"></i> Create Blog</a>
                <a href="/blog/myBlog" class="nav-link"><i class="bi bi-journal-text"></i> My Blogs</a>
                <a href="/blog/logout" class="nav-link"><i class="bi bi-person-gear"></i> Logout</a>
            </nav>
            <div class="sidebar-section-title">Quick Links</div>
            <nav class="sidebar-nav">
                <a href="../../index.html" class="nav-link"><i class="bi bi-house"></i> Back to Home</a>
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="dashboard-content">
            <div class="dashboard-topbar">
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-ghost d-lg-none" onclick="toggleSidebar()"><i class="bi bi-list"
                            style="font-size:22px;"></i></button>
                    <div class="topbar-title">
                        <h4>Create New Blog</h4>
                        <p>Write and publish your article</p>
                    </div>
                </div>

            </div>

            <div class="dashboard-main">
                <form id="createBlogForm" action="/blog/create-Blog" method="POST" enctype="multipart/form-data">

                    <!-- Title -->
                    <div class="mb-3">
                        <label>Blog Title</label>
                        <input type="text" name="title" class="form-control" required>
                    </div>

                    <!-- Content -->
                    <div class="mb-3">
                        <label>Content</label>

                        <div id="editor" contenteditable="true" class="form-control" style="height:200px;"></div>

                        <!-- Hidden input for content -->
                        <input type="hidden" name="content" id="contentInput">
                    </div>

                    <!-- Excerpt -->
                    <div class="mb-3">
                        <label>Excerpt</label>
                        <textarea name="excerpt" class="form-control" required></textarea>
                    </div>

                    <!-- Category -->
                    <div class="mb-3">
                        <label>Category</label>
                        <select name="category" class="form-control" required>
                            <option value="">Select Category</option>
                            <option value="technology">Technology</option>
                            <option value="programming">Programming</option>
                            <option value="design">Design</option>
                        </select>
                    </div>

                    <!-- Tags -->
                    <div class="mb-3">
                        <label>Tags</label>
                        <input type="text" name="tags" class="form-control" placeholder="nodejs,javascript,web">
                    </div>

                    <!-- Featured Image -->
                    <div class="mb-3">
                        <label>Featured Image</label>
                        <input type="file" name="image" class="form-control">
                    </div>

                    <button type="submit" class="btn btn-primary">Publish Blog</button>

                </form>
            </div>
        </div>
    </div>

    <div id="toastContainer" style="position:fixed; top:80px; right:20px; z-index:9999; width:360px;"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.getElementById("createBlogForm").addEventListener("submit", function () {

            const content = document.getElementById("editor").innerHTML;

            document.getElementById("contentInput").value = content;

        });
    </script>
</body>

</html>