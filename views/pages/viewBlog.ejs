<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Read the full article on BlogSphere.">
    <title>Blog Post — BlogSphere</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="../../assets/css/styles.css" rel="stylesheet">
    <style>
        .blog-content {
            font-size: 17px;
            line-height: 1.9;
        }

        .blog-content h3 {
            margin: 32px 0 16px;
            font-size: 24px;
        }

        .blog-content p {
            margin-bottom: 20px;
            color: var(--clr-text-secondary);
        }

        .blog-content blockquote {
            border-left: 4px solid var(--clr-primary);
            padding: 16px 24px;
            margin: 24px 0;
            background: var(--clr-surface);
            border-radius: 0 var(--radius-btn) var(--radius-btn) 0;
            font-style: italic;
            color: var(--clr-text);
        }

        .blog-hero-img {
            width: 100%;
            height: 400px;
            object-fit: cover;
            border-radius: var(--radius-modal);
            box-shadow: var(--shadow-hover);
        }

        .share-btn {
            width: 44px;
            height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--radius-circle);
            border: 1px solid var(--clr-border);
            color: var(--clr-text-secondary);
            transition: var(--transition);
            cursor: pointer;
            background: #fff;
        }

        .share-btn:hover {
            background: var(--clr-gradient);
            color: #fff;
            border-color: transparent;
            transform: scale(1.1);
        }

        .like-btn {
            cursor: pointer;
            transition: var(--transition);
        }

        .like-btn:hover,
        .like-btn.liked {
            color: var(--clr-error);
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-custom fixed-top">
        <div class="container">
            <a class="navbar-brand" href="../../index.html"><i class="bi bi-globe2"></i> BlogSphere</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" href="../../index.html">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="blog-listing.html">Blogs</a></li>
                    <li class="nav-item"><a class="nav-link" href="category.html">Categories</a></li>
                    <li class="nav-item"><a class="nav-link" href="search-results.html">Search</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <a href="login.html" class="btn btn-ghost">Login</a>
                    <a href="register.html" class="btn btn-gradient">Get Started</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- BLOG CONTENT -->
    <section style="padding-top:100px;" class="section-padding">
        <div class="container">
            <div class="row g-5">
                <!-- Main Content -->
                <div class="col-lg-12">
                    <div class="fade-in" >
                        <div class="blog-container">

                            <h1 class="blog-title">
                                <%= blog.title %>
                            </h1>

                            <div class="blog-meta ">
                                <h6 class="font-bold">Published on <%= blog.createdAt.toDateString() %></h6>
                            </div>

                            <img src="/uploads/<%= blog.image %>" width="100%" class="blog-image">

                            <p class="mt-5">
                                <%= blog.content %>
                            </p>

                        </div>

                    </div>

                    <!-- Comments Section -->
                    <div class="mt-5 pt-4 border-top" id="commentsSection">
                        <h4 class="mb-4"><i class="bi bi-chat-dots me-2"></i>Comments</h4>

                        <!-- Add Comment -->
                        <div class="card-custom p-4 mb-4">
                            <h6 class="mb-3">Leave a Comment</h6>
                            <textarea class="form-control form-control-custom mb-3" rows="3" id="commentText"
                                placeholder="Write your thoughts..."></textarea>
                            <button class="btn btn-gradient btn-sm" id="postCommentBtn">Post Comment</button>
                        </div>

                        <div id="commentsList">
                            <!-- Rendered by JS -->
                        </div>
                    </div>
                </div>

                <!-- Sidebar -->
              
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer-section">
        <div class="container">
            <div class="footer-bottom" style="border-top:none; margin-top:0;">
                <p>&copy; 2025 BlogSphere. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <div id="toastContainer" style="position:fixed; top:80px; right:20px; z-index:9999; width:360px;"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="../../models/blogModel.js"></script>
    <script src="../../models/BlogModel.js"></script>
    <script src="../../models/CategoryModel.js"></script>
    <script src="../../models/CommentModel.js"></script>
    <script src="../../controllers/MainController.js"></script>
      
</body>

</html>